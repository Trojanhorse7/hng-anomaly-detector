# Copy to `.env` and fill in (docker compose `env_file` loads this for `detector`).
# Used by config.yaml: slack.webhook_url → ${SLACK_WEBHOOK_URL}

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/HERE

# Optional: override paths if you use the same pattern in config.yaml, e.g.
# HNG_DATA=/app/data
# audit_log_path: "${HNG_DATA}/audit.log"
